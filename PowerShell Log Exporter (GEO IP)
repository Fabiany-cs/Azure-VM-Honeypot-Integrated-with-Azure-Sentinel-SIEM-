# ---------------------------------------------------------------------------
# Format a datetime into the log timestamp format: yyyy-MM-dd HH:mm:ss
# ---------------------------------------------------------------------------
function Format-Timestamp {
    param([datetime]$Dt)
    return $Dt.ToString("yyyy-MM-dd HH:mm:ss")
}

# ---------------------------------------------------------------------------
# Call the ipgeolocation.io API and return a hashtable of geo fields.
# Returns $null if the call fails.
# ---------------------------------------------------------------------------
function Get-GeoData {
    param(
        [string]$IpAddress,
        [string]$Key
    )

    $uri = "https://api.ipgeolocation.io/ipgeo?apiKey=$Key&ip=$IpAddress"

    try {
        $response = Invoke-RestMethod -Uri $uri -UseBasicParsing -TimeoutSec 10
        return @{
            Latitude  = if ($response.latitude)     { $response.latitude }     else { "null" }
            Longitude = if ($response.longitude)    { $response.longitude }    else { "null" }
            State     = if ($response.state_prov -ne "") { $response.state_prov } else { "null" }
            Country   = if ($response.country_name -ne "") { $response.country_name } else { "null" }
        }
    }
    catch {
        Write-Warning "Geo lookup failed for $IpAddress : $_"
        return $null
    }
}

# ---------------------------------------------------------------------------
# Build a log line from field values
# ---------------------------------------------------------------------------
function Build-LogLine {
    param(
        [string]$Latitude,
        [string]$Longitude,
        [string]$DestHost,
        [string]$Username,
        [string]$SourceIp,
        [string]$State,
        [string]$Country,
        [string]$Timestamp
    )

    $label = "$Country - $SourceIp"
    return "latitude:$Latitude,longitude:$Longitude,destinationhost:$DestHost,username:$Username,sourcehost:$SourceIp,state:$State,country:$Country,label:$label,timestamp:$Timestamp"
}

# ---------------------------------------------------------------------------
# XPath filter for Event ID 4625 (failed logon)
# ---------------------------------------------------------------------------
$XmlFilter = @'
<QueryList>
  <Query Id="0" Path="Security">
    <Select Path="Security">*[System[(EventID='4625')]]</Select>
  </Query>
</QueryList>
'@

# ---------------------------------------------------------------------------
# Main — initialise log file, then poll in a loop
# ---------------------------------------------------------------------------

# Validate API key is set
if ($ApiKey -eq "YOUR_API_KEY_HERE") {
    Write-Error "Please set your ipgeolocation.io API key in the `$ApiKey parameter."
    exit 1
}

# Create log file and seed with samples if it does not exist
if (-not (Test-Path -Path $LogFilePath)) {
    New-Item -ItemType File -Path $LogFilePath -Force | Out-Null
    Write-SampleLogs -Path $LogFilePath
}

# Load existing log content into a HashSet for O(1) duplicate detection
# We key on the timestamp+sourceIp combination to avoid redundant API calls.
$seenEntries = [System.Collections.Generic.HashSet[string]]::new()

Get-Content -Path $LogFilePath | ForEach-Object {
    # Extract "timestamp:YYYY-MM-DD HH:mm:ss" and "sourcehost:x.x.x.x"
    if ($_ -match 'timestamp:([^,]+).*sourcehost:([^,]+)') {
        [void]$seenEntries.Add("$($Matches[1])|$($Matches[2])")
    }
}

Write-Host "[START] Monitoring for failed RDP logons. Press Ctrl+C to stop." -ForegroundColor Green
Write-Host "[INFO]  Log file: $LogFilePath" -ForegroundColor Gray

while ($true) {
    Start-Sleep -Seconds $PollSeconds

    # Retrieve all 4625 events; suppress error if log is empty
    $events = Get-WinEvent -FilterXml $XmlFilter -ErrorAction SilentlyContinue
    if (-not $events) { continue }

    foreach ($event in $events) {

        # Property index 19 = source IP address
        $sourceIp = $event.Properties[19].Value

        # Skip if the IP is missing, a loopback, or an APIPA address
        if ([string]::IsNullOrWhiteSpace($sourceIp) -or
            $sourceIp.Length -lt 7         -or
            $sourceIp -eq '-'              -or
            $sourceIp -eq '127.0.0.1'     -or
            $sourceIp -eq '::1'           -or
            $sourceIp -like '169.254.*') {
            continue
        }

        $timestamp = Format-Timestamp -Dt $event.TimeCreated
        $entryKey  = "$timestamp|$sourceIp"

        # Skip duplicates (already logged this exact event)
        if ($seenEntries.Contains($entryKey)) { continue }

        # Properties reference for Event ID 4625:
        #   [5]  = Target Account Name (the attempted username)
        #   [11] = Workstation Name (source)
        $username    = $event.Properties[5].Value
        $sourceHost  = $event.Properties[11].Value
        $destHost    = $event.MachineName

        # Geo lookup — throttle to stay within free-tier rate limits
        Start-Sleep -Milliseconds 500
        $geo = Get-GeoData -IpAddress $sourceIp -Key $ApiKey

        if ($null -eq $geo) {
            # Log entry without geo data so we don't lose the event
            $geo = @{ Latitude = "null"; Longitude = "null"; State = "null"; Country = "null" }
        }

        $logLine = Build-LogLine `
            -Latitude  $geo.Latitude  `
            -Longitude $geo.Longitude `
            -DestHost  $destHost      `
            -Username  $username      `
            -SourceIp  $sourceIp      `
            -State     $geo.State     `
            -Country   $geo.Country   `
            -Timestamp $timestamp

        # Append to log file
        $logLine | Out-File -FilePath $LogFilePath -Append -Encoding utf8

        # Mark as seen so we skip it on the next poll
        [void]$seenEntries.Add($entryKey)

        Write-Host "[EVENT] $logLine" -ForegroundColor Magenta
    }
}
