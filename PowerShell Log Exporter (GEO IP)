# =============================================================================
# Get-FailedRDP-GeoData.ps1
# Azure Honeypot Lab - Failed RDP Geolocation Logger
#
# Prerequisites:
#   - Free API key from https://ipgeolocation.io/
#   - Run as Administrator (required to read Security event log)
#   - Windows 10/11 or Windows Server 2016+
#
# Usage:
#   Set $API_KEY below, then run:
#   .\Get-FailedRDP-GeoData.ps1
# =============================================================================

#Requires -RunAsAdministrator

[CmdletBinding()]
param (
    [string]$ApiKey      = "###################",   # <-- Replace with your ipgeolocation.io key
    [string]$LogFilePath = "C:\ProgramData\failed_rdp.log",
    [int]   $PollSeconds = 5                        # How often to poll Event Viewer
)

